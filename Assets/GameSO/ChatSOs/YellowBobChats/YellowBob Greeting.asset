  mainCharacter: {fileID: 11400000, guid: 7f3cc91fdcfd4a14984d0ec96da48d7f, type: 2}
  dialogLines:
  - speaker: {fileID: 11400000, guid: 7f3cc91fdcfd4a14984d0ec96da48d7f, type: 2}
    text: Hello! I'am Yellow Bob.
  - speaker: {fileID: 11400000, guid: 7f3cc91fdcfd4a14984d0ec96da48d7f, type: 2}
    text: Is PurpleBob asked you to find me?
  - speaker: {fileID: 11400000, guid: e69c09f810cffc64bb4ecc29855d9d11, type: 2}
    text: Now can I talk with him?
  - speaker: {fileID: 11400000, guid: 7f3cc91fdcfd4a14984d0ec96da48d7f, type: 2}
    text: Of course, sure.
